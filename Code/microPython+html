# Write the files if they don't exist or content differs
index_path = os.path.join(TEMPLATES_DIR, 'index.html')
style_path = os.path.join(STATIC_DIR, 'style.css')

def write_if_diff(path, content):
    try:
        if os.path.exists(path):
            with open(path, 'r', encoding='utf-8') as f:
                old = f.read()
            if old == content:
                return
        with open(path, 'w', encoding='utf-8') as f:
            f.write(content)
        print(f'Wrote: {path}')
    except Exception as e:
        print('Error writing', path, e)

write_if_diff(index_path, INDEX_HTML)
write_if_diff(style_path, STYLE_CSS)

# ----------------------
# Helper to fetch and normalize data
# ----------------------

def fetch_api_data():
    try:
        resp = requests.get(API_URL, timeout=10)
        resp.raise_for_status()
        payload = resp.json()
        data = payload.get('data') if isinstance(payload, dict) else payload
        if not isinstance(data, list):
            return []
        # Normalize rows: ensure keys exist and parse floats when possible
        normalized = []
        for row in data:
            if not isinstance(row, dict):
                continue
            normalized.append({
                'pH': tryfloat(row.get('pH')),
                'Temperature (°C)': tryfloat(row.get('Temperature (°C)')),
                'Turbidity (NTU)': tryfloat(row.get('Turbidity (NTU)')),
                'Dissolved Oxygen (mg/L)': tryfloat(row.get('Dissolved Oxygen (mg/L)')),
                'Conductivity (µS/cm)': tryfloat(row.get('Conductivity (µS/cm)')),
            })
        return normalized
    except Exception as e:
        print('Error fetching API:', e)
        return []


def tryfloat(v):
    if v is None:
        return None
    try:
        return float(v)
    except Exception:
        try:
            # sometimes values have extra whitespace
            return float(str(v).strip())
        except Exception:
            return None

