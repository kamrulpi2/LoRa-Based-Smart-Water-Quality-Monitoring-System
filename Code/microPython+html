@app.route('/')
def index():
    return render_template('index.html')

@app.route('/data')
def data_route():
    data = fetch_api_data()
    return jsonify({'data': data})

@app.route('/chart.png')
def chart_png():
    # fetch data
    data = fetch_api_data()
    # prepare x (reading indices) and y series
    x = list(range(1, len(data)+1))
    ph = [d['pH'] for d in data]
    temp = [d['Temperature (°C)'] for d in data]
    turb = [d['Turbidity (NTU)'] for d in data]
    do = [d['Dissolved Oxygen (mg/L)'] for d in data]
    cond = [d['Conductivity (µS/cm)'] for d in data]

    plt.figure(figsize=(10,4.5), dpi=100)
    ax = plt.gca()
    # Plot each series if it has at least one non-None value
    if any(v is not None for v in ph):
        ax.plot(x, ph, marker='o', label='pH')
    if any(v is not None for v in temp):
        ax.plot(x, temp, marker='o', label='Temperature (°C)')
    if any(v is not None for v in turb):
        ax.plot(x, turb, marker='o', label='Turbidity (NTU)')
    if any(v is not None for v in do):
        ax.plot(x, do, marker='o', label='Dissolved O₂ (mg/L)')
    if any(v is not None for v in cond):
        ax.plot(x, cond, marker='o', label='Conductivity (µS/cm)')

    ax.set_xlabel('Readings')
    ax.set_ylabel('Value')
    ax.set_title('Water Quality Trends')
    ax.grid(True, linestyle='--', alpha=0.4)
    ax.legend(loc='lower center', bbox_to_anchor=(0.5, -0.35), ncol=3)

    plt.tight_layout()

    buf = io.BytesIO()
    plt.savefig(buf, format='png', bbox_inches='tight')
    plt.close()
    buf.seek(0)

    # send image with cache-control disabled so frontend can refresh easily
    return send_file(buf, mimetype='image/png', as_attachment=False, download_name='chart.png')

